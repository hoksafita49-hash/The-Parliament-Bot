# Discord Bot 基础配置（必填）
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_id

# 命令注册目标服务器ID列表（必填，逗号分隔）
# 示例：GUILD_IDS=123456789012345678,987654321098765432
GUILD_IDS=your_guild_id_1,your_guild_id_2

# ===== 以下为可选配置（按需填写） =====

# 频道总结模块
SUMMARY_MAX_MESSAGES=1000
SUMMARY_FILE_RETENTION_HOURS=24
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gemini-2.5-pro

# 总结模块的最高管理员身份组 ID
SUMMARY_ADMIN_ROLE_IDS=

# 身份组同步系统（可选）
# 多链路 JSON 配置示例：
# ROLE_SYNC_LINKS_JSON=[{"linkId":"main_to_sub1","sourceGuildId":"111111111111111111","targetGuildId":"222222222222222222","enabled":true,"defaultConflictPolicy":"source_of_truth_main"}]
ROLE_SYNC_LINKS_JSON=[]

# 同步 worker 配置（可选）
# 队列轮询间隔（毫秒），默认 3000
ROLE_SYNC_WORKER_INTERVAL_MS=3000
# 每轮最多处理任务数，默认 20
ROLE_SYNC_WORKER_BATCH_SIZE=20
# fast 通道每轮最多处理任务数（默认按总批次70%估算）
ROLE_SYNC_WORKER_FAST_BATCH_SIZE=14
# normal 通道每轮最多处理任务数（默认与总批次一致）
ROLE_SYNC_WORKER_NORMAL_BATCH_SIZE=20

# 自动对账（可选）
# 是否启用自动对账（true/false）
ROLE_SYNC_AUTO_RECONCILE_ENABLED=false
# 自动对账周期（毫秒），默认 15 分钟
ROLE_SYNC_AUTO_RECONCILE_INTERVAL_MS=900000
# 每条链路每轮最多扫描成员数（从交集成员轮询）
ROLE_SYNC_AUTO_RECONCILE_MAX_MEMBERS_PER_LINK=20

#身份组数据库配置页面的验证需求（可选）
DISCORD_OAUTH_CLIENT_SECRET=<from Discord Developer Portal>
DISCORD_OAUTH_REDIRECT_URI=http://localhost:3847/callback

# ===== SelfRole 测试辅助命令（仅测试环境启用） =====
# 开启后会额外注册 /自助身份组申请-测试 用于手动触发过期/生命周期/巡检等。
# 正式上线请保持关闭或移除该变量。
SELF_ROLE_ENABLE_TEST_COMMANDS=false

# ===== 命令同步策略（可选） =====
# clientReady 时会向 GUILD_IDS 列表逐个 rest.put 刷新命令。
# 若开启严格模式，当任意 guild 注册失败时将直接抛错中止启动（推荐测试环境开启）。
STRICT_COMMAND_SYNC=false

# 可选：清空该应用的全局命令（Global Commands）。
# 适用于你曾用同一个 bot token/应用在其它项目里注册过全局命令，导致测试服里一直残留旧命令的情况。
# 注意：全局命令的传播/删除在 Discord 侧可能有缓存延迟（通常可达 ~1 小时）。
CLEAR_GLOBAL_COMMANDS=false


# ===== SelfRole 异常报告（可选） =====
# 当出现 DM 失败/一致性异常时，系统会发送一次性显眼错误报告（Embed），并可选 @ 一个管理员身份组。
# 不填则不 ping。
SELF_ROLE_ALERT_MENTION_ROLE_ID=


# ===== SelfRole 成员缓存/现任统计（可选） =====
# Discord.js 的 role.members.size 依赖 guild.members.cache。
# 机器人重启后缓存可能很不完整，导致面板“现任人数=0/空缺异常”。
# 本系统会按需调用 guild.members.fetch() 来填充缓存。
#
# auto: 仅在成员数不超过 MAX_GUILD_SIZE 且缓存覆盖率低于阈值时自动拉取（默认）
# always: 只要未在 MAX_AGE 内拉取过，就会尝试拉取（谨慎：大服可能很重）
# never: 从不自动拉取（面板现任统计可能不准）
SELF_ROLE_MEMBER_FETCH_MODE=auto

# auto 模式下：当服务器 memberCount 超过该值时，不会自动全量拉取成员（避免大服内存/耗时爆炸）
SELF_ROLE_MEMBER_FETCH_MAX_GUILD_SIZE=5000

# 拉取成员时的超时（毫秒）。discord.js 默认 120000。
SELF_ROLE_MEMBER_FETCH_TIMEOUT_MS=30000

# 成员缓存拉取成功后，在该时间窗口内不重复拉取（分钟）
SELF_ROLE_MEMBER_FETCH_MAX_AGE_MINUTES=10

# 缓存覆盖率阈值（0~1）。auto 模式下：coverage < threshold 才会尝试拉取
SELF_ROLE_MEMBER_FETCH_COVERAGE_THRESHOLD=0.8

# ===== 诊断/稳健性（可选） =====
# REST 请求超时（毫秒）。默认 15000。
DISCORD_REST_TIMEOUT_MS=15000

# 定期输出健康日志（分钟）。0=关闭。
HEALTH_LOG_INTERVAL_MINUTES=0

# 若发生 uncaughtException 时是否直接退出进程（true/false）。建议配合 pm2 等守护工具使用。
FATAL_EXIT_ON_EXCEPTION=false

# 交互调试日志（true/false）。用于排查“命令无响应但控制台无日志”。
INTERACTION_DEBUG_LOG=false
